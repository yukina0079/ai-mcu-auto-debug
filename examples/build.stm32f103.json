{
  "backend": "cmake",
  "source_dir": ".",
  "build_dir": "build/stm32f103_blinky",
  "configure_command": [
    "cmake",
    "-S",
    "examples/firmware/stm32f103_blinky",
    "-B",
    "build/stm32f103_blinky",
    "-G",
    "Ninja",
    "-DCMAKE_TOOLCHAIN_FILE=examples/firmware/stm32f103_blinky/arm-gcc-toolchain.cmake"
  ],
  "build_command": [
    "cmake",
    "--build",
    "build/stm32f103_blinky"
  ],
  "flash_command": [
    "openocd",
    "-f",
    "interface/stlink.cfg",
    "-f",
    "target/stm32f1x.cfg",
    "-c",
    "program build/stm32f103_blinky/firmware.elf verify reset exit"
  ],
  "smoke_test_command": [
    "python",
    "-m",
    "ai_mcu_debug.cli",
    "elf-check",
    "--elf",
    "build/stm32f103_blinky/firmware.elf"
  ],
  "repair_command": null,
  "repair_timeout_s": 600,
  "max_repair_iterations": 3
}
